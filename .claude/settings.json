{
  "permissions": {
    "defaultMode": "auto"
  },
  "extraKnownMarketplaces": {
    "bytewyrd": {
      "source": {
        "source": "github",
        "repo": "bytewyrd/claude-bytewyrd"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "excludedCommands": [
      "pkgdev",
      "pkgcheck",
      "gh",
      "ebuild"
    ]
  },
  "enabledPlugins": {
    "bytewyrd@bytewyrd": true,
    "github@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  }
}
