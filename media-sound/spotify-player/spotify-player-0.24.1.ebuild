inherit cargo

DESCRIPTION="A Spotify player in the terminal with full feature parity"
HOMEPAGE="https://github.com/aome510/spotify-player"
SRC_URI="
	https://github.com/aome510/${PN}/archive/refs/tags/v${PV}.tar.gz -> ${P}.tar.gz
	${CARGO_CRATE_URIS}
"

LICENSE="MIT"
# Dependent crate licenses
LICENSE+="
	0BSD Apache-2.0 Apache-2.0-with-LLVM-exceptions BSD BSD-2
	Boost-1.0 ISC LGPL-3 LGPL-3+ MIT MPL-2.0 Unicode-3.0 Unicode-DFS-2016
	Unlicense ZLIB
"
SLOT="0"
KEYWORDS="~amd64"
IUSE="daemon fzf image +media-control +notify pulseaudio sixel +streaming"
REQUIRED_USE="
	daemon? ( streaming )
	pulseaudio? ( streaming )
	sixel? ( image )
"

RDEPEND="
	dev-libs/openssl:=
	media-libs/alsa-lib
	media-control? ( sys-apps/dbus:= )
	notify? ( x11-libs/libnotify )
	pulseaudio? ( media-libs/libpulse )
	sixel? ( media-libs/libsixel:= )
"
DEPEND="${RDEPEND}"
BDEPEND="
	virtual/pkgconfig
"

QA_FLAGS_IGNORED="usr/bin/spotify_player"

src_configure() {
	local myfeatures=(
		$(usev daemon)
		$(usev fzf)
		$(usev image)
		$(usev media-control)
		$(usev notify)
		$(usev sixel)
		$(usex streaming "$(usex pulseaudio pulseaudio-backend alsa-backend)" '')
	)
	cargo_src_configure --no-default-features
}

src_install() {
	cargo_src_install --path ./spotify_player
	dodoc README.md
}
